# MANIFEST.in

# Include core project files
include README.md
include LICENSE
include pyproject.toml
include setup.cfg
include MANIFEST.in

# Include report templates
recursive-include momo_ml/report *.html

# Exclude development/test/example artifacts
prune tests
prune examples
global-exclude *.pyc
global-exclude __pycache__/
global-exclude .DS_Store
global-exclude *.ipynb
global-exclude *.log
